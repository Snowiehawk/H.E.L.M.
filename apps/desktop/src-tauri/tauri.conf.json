{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "H.E.L.M.",
  "version": "0.1.0",
  "identifier": "com.openai.helm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "H.E.L.M.",
        "width": 1480,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "asset:", "data:", "blob:"],
        "font-src": ["'self'", "data:"],
        "connect-src": ["ipc:", "http://ipc.localhost"],
        "worker-src": ["'self'", "blob:"],
        "child-src": ["'self'", "blob:"],
        "object-src": ["'none'"],
        "base-uri": ["'none'"],
        "frame-ancestors": ["'none'"]
      },
      "devCsp": {
        "default-src": ["'self'", "http://localhost:1420", "http://127.0.0.1:1420"],
        "script-src": ["'self'", "'unsafe-eval'", "http://localhost:1420", "http://127.0.0.1:1420"],
        "style-src": [
          "'self'",
          "'unsafe-inline'",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "data:",
          "blob:",
          "http://localhost:1420",
          "http://127.0.0.1:1420"
        ],
        "font-src": ["'self'", "data:", "http://localhost:1420", "http://127.0.0.1:1420"],
        "connect-src": [
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "ws://localhost:1420",
          "http://127.0.0.1:1420",
          "ws://127.0.0.1:1420"
        ],
        "worker-src": ["'self'", "blob:", "http://localhost:1420", "http://127.0.0.1:1420"],
        "child-src": ["'self'", "blob:", "http://localhost:1420", "http://127.0.0.1:1420"],
        "object-src": ["'none'"],
        "base-uri": ["'none'"],
        "frame-ancestors": ["'none'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
